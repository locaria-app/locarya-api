{
  "enabledPlugins": {
    "andrej-karpathy-skills@karpathy-skills": true
  },
  "extraKnownMarketplaces": {
    "karpathy-skills": {
      "source": {
        "source": "github",
        "repo": "forrestchang/andrej-karpathy-skills"
      }
    }
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push)",
      "Bash(git push origin:*)",
      "Bash(git push -u origin:*)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git rebase:*)",
      "Bash(git merge --abort)",
      "Bash(git rebase --abort)",
      "Bash(git rebase --continue)",
      "Bash(git stash:*)",
      "Bash(git worktree list:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git worktree prune)",
      "Bash(git symbolic-ref:*)",
      "Bash(git config --get:*)",
      "Bash(gh issue:*)",
      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr create:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run list:*)",
      "Bash(gh run view:*)",
      "Bash(gh api repos/*/branches/*/protection:*)",
      "Bash(sbt compile)",
      "Bash(sbt test)",
      "Bash(sbt testOnly:*)",
      "Bash(sbt scalafmtCheckAll)",
      "Bash(sbt scalafmtAll)",
      "Bash(sbt clean)",
      "Bash(sbt reload)",
      "Bash(docker compose up:*)",
      "Bash(docker compose down:*)",
      "Bash(docker compose ps:*)",
      "Bash(docker compose logs:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(find:*)",
      "Bash(rg:*)",
      "Bash(tree:*)",
      "Bash(wc:*)",
      "Bash(pwd)"
    ],
    "deny": [
      "Bash(git push --force)",
      "Bash(git push -f)",
      "Bash(git push --force origin:*)",
      "Bash(git push --force-with-lease origin main:*)",
      "Bash(git push origin main:*)",
      "Bash(git push -u origin main:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fdx:*)",
      "Bash(git branch -D main)",
      "Bash(git checkout main -- .)",
      "Bash(gh pr merge:*)",
      "Bash(rm -rf:*)",
      "Bash(rm -rf /:*)",
      "Bash(sudo:*)",
      "Bash(curl * | sh:*)",
      "Bash(curl * | bash:*)",
      "Bash(wget * | sh:*)",
      "Bash(wget * | bash:*)"
    ]
  }
}
